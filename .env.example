# ===========================================
# IconsAI Scraping v3.0 - Configuracao
# Business Intelligence Brasil
# ===========================================

# Environment
ENVIRONMENT=development
DEBUG=false

# ===========================================
# APIs de Dados Brasileiros (Gratuitas)
# ===========================================

# BrasilAPI - Dados públicos brasileiros
# URL: https://brasilapi.com.br (gratuito, sem limite)
BRASIL_API_URL=https://brasilapi.com.br/api

# ===========================================
# APIs de Busca
# ===========================================

# Serper.dev - Google Search API
# URL: https://serper.dev (2.500 buscas grátis)
SERPER_API_KEY=your_serper_api_key_here

# ===========================================
# APIs de AI/Research
# ===========================================

# Perplexity - AI Research
# URL: https://perplexity.ai
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Anthropic Claude - AI Analysis
# URL: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI - Fallback LLM (opcional)
# URL: https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# ===========================================
# APIs de Dados B2B (Opcional)
# ===========================================

# Apollo.io - LinkedIn & Contatos B2B
# URL: https://apollo.io (freemium)
APOLLO_API_KEY=your_apollo_api_key_here

# CNPJá - Regime Tributário
# URL: https://cnpja.com (plano pago necessário)
CNPJA_API_KEY=your_cnpja_api_key_here

# ===========================================
# Banco de Dados
# ===========================================

# Supabase (IconsAI Scraping)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key
SUPABASE_ANON_KEY=your_supabase_anon_key

# ===========================================
# Rate Limiting & Cache
# ===========================================

RATE_LIMIT_PERIOD=60
CACHE_TTL=3600

# ===========================================
# Logging
# ===========================================

LOG_LEVEL=INFO
LOG_FORMAT=json

# ===========================================
# Autenticação API
# ===========================================

# JWT para autenticação da API
# IMPORTANTE: Gerar chave segura em produção com: openssl rand -hex 32
JWT_SECRET_KEY=your_super_secret_jwt_key_here_change_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ===========================================
# CORS - Origens Permitidas
# ===========================================

# Lista de origens separadas por vírgula
# Em produção, especificar domínios exatos
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://app.iconsai.dev

# ===========================================
# Brasil Data Hub (Dados Geográficos + Políticos)
# ===========================================

# Supabase do projeto brasil-data-hub
# Contém tabelas:
#   - geo_municipios: capitais brasileiras
#   - dim_politicos: dados de políticos (869k registros)
#   - fato_politicos_mandatos: histórico de mandatos (942k registros)
BRASIL_DATA_HUB_URL=https://xxx.supabase.co
BRASIL_DATA_HUB_KEY=your_brasil_data_hub_service_key

# ===========================================
# Supabase Fiscal Brasil (Políticos)
# ===========================================

# Supabase do projeto iconsai-fiscal
# Contém tabelas politico e mandato_politico
FISCAL_SUPABASE_URL=https://xxx.supabase.co
FISCAL_SUPABASE_KEY=your_fiscal_supabase_service_key

# ===========================================
# Scheduler Configuration
# ===========================================

# Horário de coleta automática
SCHEDULER_ENABLED=false
SCHEDULER_HOUR=2
SCHEDULER_MINUTE=0

# ===========================================
# GitHub (Opcional - aumenta rate limit da API)
# ===========================================

GITHUB_TOKEN=your_github_token_here
